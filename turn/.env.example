# Copy to .env and fill in. Keep .env out of git (see .gitignore).

# Public hostname clients dial for STUN/TURN and the cred endpoint.
# Must have a DNS A record pointing at this box's Elastic IP.
TURN_DOMAIN=turn.example.com

# Shared HMAC secret between coturn and the cred service. Generate once:
#   openssl rand -hex 32
TURN_SECRET=

# Bearer token the desktop app must present to GET /ice. Generate once:
#   openssl rand -hex 32
ICE_API_KEY=

# How long minted credentials stay valid (seconds). 1h is plenty for a call.
CRED_TTL_SECONDS=3600

# Advertise turns:5349 (TURN over TLS). Leave false until you've mounted a cert
# into coturn (Phase 2). turn:3478 (udp+tcp) is enough to fix symmetric-NAT calls.
ENABLE_TURNS=false

# --- used only by setup.sh to template coturn/turnserver.conf ---
# This box's public (Elastic) IP and private (VPC) IP.
PUBLIC_IP=
PRIVATE_IP=
